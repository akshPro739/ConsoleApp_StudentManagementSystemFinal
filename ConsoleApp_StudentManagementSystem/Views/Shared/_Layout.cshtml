<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Student Record Management System</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ConsoleApp_StudentManagementSystem.styles.css" asp-append-version="true" />
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
            <div class="container-fluid">

                <!-- Project Name -->
                <a class="navbar-brand fw-bold"
                   asp-controller="Students"
                   asp-action="Dashboard">
                    Student Record Management System
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">

                    <ul class="navbar-nav me-auto">

                        @if (Context.Request.Cookies["RoleId"] == "1")
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Students"
                                   asp-action="Dashboard">
                                    Dashboard
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Students"
                                   asp-action="List">
                                    Students
                                </a>
                            </li>
                        }

                        @if (Context.Request.Cookies["RoleId"] == "2")
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Students"
                                   asp-action="MyRecord">
                                    My Record
                                </a>
                            </li>
                        }

                    </ul>

                    @if (Context.Request.Cookies["UserId"] != null)
                    {
                        <a asp-controller="Account"
                           asp-action="Logout"
                           class="btn btn-danger">
                            Logout
                        </a>
                    }

                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5">
        <div class="container text-center py-3">
            &copy; 2026 - Student Record Management System
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>




